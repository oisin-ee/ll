{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/post-edit-check.sh",
            "timeout": 60,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/import-validator.sh",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": ".claude/hooks/ai-antipattern-guard.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/destructive-command-guard.sh",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": ".claude/hooks/block-coauthor.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/block-todowrite.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "TodoWrite"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/context-bootstrap.sh",
            "timeout": 10,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/pre-stop-verification.sh",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/context-injector.sh",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "mode": "default",
    "rules": [
      {
        "decision": "deny",
        "if": "Bash(rm -rf|git reset --hard|git push --force|git push -f )",
        "reason": "Destructive commands require explicit user approval",
        "tool": "Bash"
      },
      {
        "decision": "allow",
        "reason": "Read-only file access",
        "tool": "Read"
      },
      {
        "decision": "allow",
        "reason": "Read-only search",
        "tool": "Glob"
      },
      {
        "decision": "allow",
        "reason": "Read-only search",
        "tool": "Grep"
      },
      {
        "decision": "allow",
        "if": "Bash(svelte-kit sync \u0026\u0026 svelte-check --tsconfig ./tsconfig.json|svelte-check --tsconfig ./tsconfig.json|vitest run|git status|git diff|git log|bd *)",
        "reason": "Safe verification and task tracking",
        "tool": "Bash"
      },
      {
        "decision": "ask",
        "if": "Bash(git commit*|git push*)",
        "reason": "Git operations require review",
        "tool": "Bash"
      },
      {
        "decision": "ask",
        "reason": "Code changes require approval",
        "tool": "Edit"
      },
      {
        "decision": "ask",
        "reason": "File creation requires approval",
        "tool": "Write"
      }
    ]
  }
}