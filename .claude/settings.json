{
  "permissions": {
    "mode": "default",
    "rules": [
      {
        "decision": "deny",
        "if": "Bash(rm -rf|git reset --hard|git push --force|git push -f )",
        "reason": "Destructive commands require explicit user approval",
        "tool": "Bash"
      },
      {
        "decision": "allow",
        "reason": "Read-only file access",
        "tool": "Read"
      },
      {
        "decision": "allow",
        "reason": "Read-only search",
        "tool": "Glob"
      },
      {
        "decision": "allow",
        "reason": "Read-only search",
        "tool": "Grep"
      },
      {
        "decision": "allow",
        "if": "Bash(svelte-kit sync && svelte-check --tsconfig ./tsconfig.json|svelte-check --tsconfig ./tsconfig.json|vitest run|git status|git diff|git log|bd *)",
        "reason": "Safe verification and task tracking",
        "tool": "Bash"
      },
      {
        "decision": "ask",
        "if": "Bash(git commit*|git push*)",
        "reason": "Git operations require review",
        "tool": "Bash"
      },
      {
        "decision": "ask",
        "reason": "Code changes require approval",
        "tool": "Edit"
      },
      {
        "decision": "ask",
        "reason": "File creation requires approval",
        "tool": "Write"
      }
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-check.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/import-validator.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/ai-antipattern-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/destructive-command-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-coauthor.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-todowrite.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/context-bootstrap.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-stop-verification.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/context-injector.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "beads-marketplace": {
      "source": {
        "source": "github",
        "repo": "steveyegge/beads"
      }
    }
  },
  "enabledPlugins": {
    "beads@beads-marketplace": true
  }
}
